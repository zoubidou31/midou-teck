{
  "name": "midou-teck",
  "version": "1.0.0",
  "description": "Never Miss a Free Game 🎮 - The ultimate Discord bot for free games, Steam deals, and Epic Games giveaways.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "deploy": "npm run build && npm start",
    "db:generate": "prisma generate",
    "db:generate:dev": "prisma generate --schema=prisma/schema.sqlite.prisma",
    "db:push": "prisma db push",
    "db:push:dev": "prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev --schema=prisma/schema.sqlite.prisma",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/database/seed.ts",
    "register-commands": "tsx src/scripts/deploy-commands.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["discord", "bot", "games", "steam", "epic", "free-games"],
  "author": "midou_Teck",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "cron": "^3.1.6",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.4",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "node-cache": "^5.1.2",
    "passport": "^0.7.0",
    "passport-discord": "^0.1.4",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.11.20",
    "@types/passport": "^1.0.16",
    "@types/passport-discord": "^0.1.11",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "prisma": "^5.10.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
