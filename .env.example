# ================================
# midou_Teck - Environment Variables
# ================================

# ---- Discord Bot ----
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret
DISCORD_GUILD_ID=your_test_guild_id_for_dev  # Optional: for guild-scoped command registration

# ---- Database ----
# Development: sqlite
# Production: postgresql
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# For PostgreSQL (production):
# DATABASE_PROVIDER=postgresql
# DATABASE_URL=postgresql://user:password@localhost:5432/midou_teck?schema=public

# ---- Web Dashboard ----
DASHBOARD_PORT=3000
DASHBOARD_URL=http://localhost:3000
SESSION_SECRET=your_very_long_random_session_secret_here_change_this
COOKIE_SECURE=false  # Set to true in production with HTTPS

# ---- APIs ----
# Steam API (optional but recommended)
STEAM_API_KEY=your_steam_api_key

# RAWG Game Database API (for /game command)
RAWG_API_KEY=your_rawg_api_key

# CheapShark API does not require a key

# ---- Bot Settings ----
BOT_PREFIX=/
BOT_OWNER_ID=your_discord_user_id
SUPPORT_SERVER_ID=your_support_server_id
SUPPORT_INVITE=https://discord.gg/yourinvite

# ---- Logging ----
LOG_LEVEL=info  # error | warn | info | debug

# ---- Node Environment ----
NODE_ENV=development  # development | production
